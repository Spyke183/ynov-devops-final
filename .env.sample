# Secrets a configurer dans GitHub : Settings > Secrets and variables > Actions.
# Ne jamais committer les vraies valeurs. Ne pas mettre les cles AWS dans le rendu.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

REGISTRY_HOST=          # ip_publique_du_registre:443
REGISTRY_USER=admin
REGISTRY_PASSWORD=

MYSQL_ROOT_PASSWORD=
ADMIN_EMAIL=
ADMIN_PASSWORD=
